{
  "crons": [
    {
      "path": "/api/cron/process-monthly-credits",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/gatekeeper-wraps",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/renew-memberships",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/renew-private-space",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/run-workflows",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/private-session-reminders",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/draft-weekly-newsletter",
      "schedule": "0 11 * * 1"
    },
    {
      "path": "/api/cron/sync-subscribers",
      "schedule": "30 3 * * *"
    }
  ],
  "headers": [
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/_next/static/chunks/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
