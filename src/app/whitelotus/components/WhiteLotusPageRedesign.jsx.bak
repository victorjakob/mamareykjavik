            <FadeUp delay={0.1}>
              <p className="text-[#a09488] text-lg md:text-xl leading-[1.9] mb-6">{t.body}</p>
            </FadeUp>
            <FadeUp delay={0.16}>
              <p className="text-[#6a5e52] text-sm italic leading-relaxed border-l-2 border-[#ff914d]/20 pl-4">
                {t.pull}
              </p>
            </FadeUp>
          </div>

          {/* Right — stat pillars */}
          <FadeUp delay={0.22} className="lg:pt-2">
            <div className="flex flex-row lg:flex-col gap-4">
              {t.stats.map((stat, i) => (
