        style={{
          background: [
            "radial-gradient(ellipse 115% 88% at 50% 46%, rgba(0,0,0,0) 18%, rgba(0,0,0,0.50) 52%, rgba(10,12,18,0.80) 100%)",
            "linear-gradient(180deg, rgba(0,0,0,0.72) 0%, rgba(0,0,0,0.24) 34%, rgba(0,0,0,0.28) 66%, rgba(0,0,0,0.88) 100%)",
            "linear-gradient(180deg, rgba(17,15,13,0.0) 0%, transparent 50%, rgba(17,15,13,1) 100%)",
