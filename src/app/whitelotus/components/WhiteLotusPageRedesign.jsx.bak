          </div>
        </FadeUp>

        <div className="grid grid-cols-1 lg:grid-cols-[1fr_280px] gap-12 lg:gap-20 items-start">

          {/* Left — headline + body */}
          <div>
            <FadeUp delay={0.05}>
              <h2
                className="font-cormorant font-light italic text-[#f0ebe3] leading-[1.18] mb-8 whitespace-pre-line"
                style={{ fontSize: "clamp(2.4rem, 5vw, 4.4rem)" }}
