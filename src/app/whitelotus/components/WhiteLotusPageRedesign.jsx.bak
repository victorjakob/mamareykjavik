                  <p
                    className="font-cormorant font-light text-[#f0ebe3] leading-none mb-2"
                    style={{ fontSize: "clamp(1.9rem, 4vw, 2.8rem)" }}
                  >
                    {stat.number}
                  </p>
                  <p className="text-[10px] uppercase tracking-[0.35em] text-[#8a7e72]">{stat.label}</p>
                </motion.div>
              ))}
            </div>
          </FadeUp>
        </div>
      </div>
    </section>
  );
}

